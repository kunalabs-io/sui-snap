    "@mysten/wallet-standard": "^0.20.3",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "@metamask/snaps-cli": "^8.4.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
