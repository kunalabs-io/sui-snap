{
  "name": "@kunalabs-io/sui-snap-wallet",
  "version": "0.5.0",
  "license": "Apache-2.0",
  "author": "Kuna Labs <build@kunalabs.io>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "source": "./src/types.ts",
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./errors": {
      "source": "./src/errors.ts",
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "default": "./dist/errors.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kunalabs-io/sui-snap.git"
  },
  "scripts": {
    "clean": "rm -rf tsconfig.tsbuildinfo ./dist",
    "build": "pnpm clean && pnpm tsup ./src/index.ts ./src/types.ts ./src/errors.ts --format esm --sourcemap --experimental-dts",
    "dev": "pnpm build --watch",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@metamask/detect-provider": "^2.0.0",
    "@metamask/providers": "^22.1.1",
    "@mysten/sui": "^2.17.0",
    "@mysten/wallet-standard": "^0.20.3",
    "superstruct": "^2.0.2"
  }
}
